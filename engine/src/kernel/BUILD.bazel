licenses(["notice"])

load("@rules_cc//cc:defs.bzl", "cc_shared_library")
load("//tools:macos_codesign.bzl", "macos_codesigned_artifact")

package(default_visibility = ["//visibility:public"])

cc_library(
    name = "kernel_types",
    hdrs = ["public/kernel_types.h"],
    includes = [".."],
)

cc_library(
    name = "kernel_api",
    hdrs = ["public/kernel_api.h"],
    includes = [".."],
    deps = [":kernel_types"],
)

cc_library(
    name = "tick_loop",
    srcs = ["src/tick_loop.cc"],
    hdrs = ["src/tick_loop.h"],
    includes = [".."],
    deps = [":kernel_types"],
)

genrule(
    name = "build_info_macros",
    srcs = ["VERSION"],
    outs = ["src/build_info_macros.h"],
    cmd = """
base_version="$$(tr -d '[:space:]' < $(location :VERSION))"
if [ -z "$$base_version" ]; then
  base_version="0.0.0"
fi
commit_count="$$(git rev-list --count HEAD 2>/dev/null || echo 0)"
git_commit="$$(git rev-parse --short HEAD 2>/dev/null || echo unknown)"
build_timestamp="$$(git show -s --format=%ct HEAD 2>/dev/null || echo unknown)"
module_version="$${base_version}+r$${commit_count}"
{
  printf '#ifndef KERNEL_SRC_BUILD_INFO_MACROS_H_\\n'
  printf '#define KERNEL_SRC_BUILD_INFO_MACROS_H_\\n\\n'
  printf '#define NETWORK_KERNEL_MODULE_VERSION "%s"\\n' "$$module_version"
  printf '#define NETWORK_KERNEL_GIT_COMMIT "%s"\\n' "$$git_commit"
  printf '#define NETWORK_KERNEL_BUILD_TIMESTAMP "%s"\\n\\n' "$$build_timestamp"
  printf '#endif  // KERNEL_SRC_BUILD_INFO_MACROS_H_\\n'
} > "$@"
""",
    local = True,
)

cc_library(
    name = "kernel",
    srcs = [
        "src/build_info.cc",
        "src/kernel.cc",
        "src/kernel_api.cc",
        "src/lan_discovery.cc",
        "src/render_state_builder.cc",
    ],
    hdrs = [
        ":build_info_macros",
        "src/build_info.h",
        "src/kernel.h",
        "src/lan_discovery.h",
        "src/render_state_builder.h",
    ],
    includes = [".."],
    deps = [
        ":kernel_api",
        ":kernel_types",
        ":tick_loop",
        "//engine/src/protocol:protocol",
        "//engine/src/simulation:simulation",
        "//engine/src/sync:sync",
        "//engine/src/transport:transport",
        "//engine/src/world:world",
        "@fmt//:fmt",
        "@glm//:glm",
        "@spdlog//:spdlog",
    ],
)

alias(
    name = "network_kernel_shared",
    actual = select({
        "//engine:macos": ":_network_kernel_shared_macos_signed",
        "//engine:mingw_w64": ":_network_kernel_shared_mingw_stripped",
        "//conditions:default": ":network_kernel_shared_unsigned",
    }),
)

