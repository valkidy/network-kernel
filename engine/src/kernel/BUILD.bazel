            "-Wl,-exported_symbol,_GameServer_CreateWithGameplayCatalogFromMemory",
            "-Wl,-exported_symbol,_GameServer_Destroy",
            "-Wl,-exported_symbol,_GameServer_HandleEvent",
            "-Wl,-exported_symbol,_GameServer_Tick",
