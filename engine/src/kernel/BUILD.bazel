macos_codesigned_artifact(
    name = "_network_kernel_shared_macos_signed",
    src = ":network_kernel_shared_unsigned",
    out = "signed/libnetwork_kernel.dylib",
)

cc_shared_library(
    name = "_network_kernel_shared_mingw_unstripped",
    deps = [
        ":kernel",
        "//game_server:game_server_bridge",
    ],
    shared_lib_name = "network_kernel.unstripped.dll",
    user_link_flags = [
        "-lws2_32",
        "-lbcrypt",
        "-lcrypt32",
        "-liphlpapi",
        "-lwinpthread",
        "-lwinmm",

        "-static-libgcc",
        "-static-libstdc++",
        "-lstdc++",
    ],
    target_compatible_with = select({
        "//engine:mingw_w64": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    visibility = ["//visibility:private"],
)

genrule(
    name = "_network_kernel_shared_mingw_stripped",
    srcs = [":_network_kernel_shared_mingw_unstripped"],
    outs = ["network_kernel.dll"],
    cmd = "x86_64-w64-mingw32-strip --strip-unneeded $(location :_network_kernel_shared_mingw_unstripped) -o $@",
    target_compatible_with = select({
        "//engine:mingw_w64": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    visibility = ["//visibility:private"],
)
